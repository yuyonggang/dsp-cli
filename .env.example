# SAP Datasphere Connection Configuration
# ⚠️ DO NOT commit the actual .env file with real credentials!
# Copy this file to .env and fill in your actual credentials

# Datasphere Tenant URL
DATASPHERE_HOST=https://your-tenant.eu10.hcs.cloud.sap

# OAuth Client Credentials (Required)
CLIENT_ID=your-client-id
CLIENT_SECRET=your-client-secret

# OAuth URLs (adjust region if needed: eu10, us10, ap10, etc.)
AUTHORIZATION_URL=https://your-tenant.authentication.eu10.hana.ondemand.com/oauth/authorize
TOKEN_URL=https://your-tenant.authentication.eu10.hana.ondemand.com/oauth/token

# How to get OAuth credentials:
# 1. Log in to SAP Datasphere UI
# 2. Go to System → Administration → App Integration
# 3. Create a new OAuth Client
# 4. Select "Authorization Code" flow
# 5. Copy the Client ID and Client Secret
# 6. Update the URLs to match your tenant name and region

# Optional Configuration
CLI_HTTP_PORT=8080
LOG_LEVEL=4

# Default Space for Testing
TEST_SPACE_ID=YOUR_SPACE_ID

